## Docker Compose auto-loads this file when named ".env" in repo root.
## Copy this file to ".env" and fill in values.

# Spring name + New Relic OTLP service.name (metrics entity in NR)
APP_NAME=roman-numerals-service-local

# API key required for all protected endpoints
APP_API_KEY=my-test-key

# Header name expected for the API key
API_KEY_HEADER=x-api-key

# Optional: set fixed thread pool size for range conversion.
# 0 = auto (based on CPU)
RANGE_EXECUTOR_THREADS=0

# --- New Relic (optional) --- change to true to enable metrics export
NEW_RELIC_METRICS_EXPORT=false
NEW_RELIC_LICENSE_KEY=
